# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pdf_service
DB_USERNAME=root
DB_PASSWORD=secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage backend: "s3" or "azure"
STORAGE_BACKEND=s3

# S3 (when STORAGE_BACKEND=s3)
S3_BUCKET=my-pdf-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret>

# Azure Blob (when STORAGE_BACKEND=azure)
AZURE_STORAGE_CONNECTION_STRING=<your-connection-string>
AZURE_CONTAINER_NAME=pdfs

# Pre-signed URL expiration (seconds)
PRESIGNED_URL_TTL=1800
